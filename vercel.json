{
  "version": 2,
  "buildCommand": "cd server && npm install",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "server/**/*.js",
        "server/**/*.json",
        "server/museumpass.db",
        "server/.env"
      ],
      "excludeFiles": "server/node_modules/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/$1" }
  ]
}
