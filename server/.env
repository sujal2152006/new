# ============================
# Museum Pass – Environment Config
# ============================

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=museumpass_super_secret_key_2026
JWT_EXPIRES_IN=7d

# API Key (for external/programmatic API access)
API_KEY=mp_api_key_2026_secure

# Frontend URL (for CORS – set to your deployed URL in production)
CLIENT_URL=http://localhost:5000

# Email (optional – for ticket emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
